# Discord Bot Token — https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Groq API Key (ฟรี) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Custom Search API — https://console.cloud.google.com/
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here

# Google Custom Search Engine ID — https://programmablesearchengine.google.com/
GOOGLE_SEARCH_CX=your_search_engine_cx_here

# Discord Channel ID ที่ bot จะตอบ (คลิกขวาที่ channel → Copy Channel ID)
CHAT_CHANNEL_ID=your_channel_id_here
